@model MvcUsersProject.Models.User
<h1>Add User</h1>
<form method="post" action='/Users/Store'>
<div class="mb-3">
    <label class="form-label">Name</label>
    <input type="text" name="Name" class="form-control" placeholder="Enter your name" value="@Model.Name">
        <span class="text-danger" asp-validation-for="Name"> </span>
</div>

<div class="mb-3">
    <label class="form-label">Email</label>
    <input type="email" name="Email" class="form-control" placeholder="name@example.com" value="@Model.Email"   >
        <span class="text-danger" asp-validation-for="Email" >  </span>

</div>

<div class="mb-3">
    <label class="form-label">Age</label>
    <input type="number" name="Age"class="form-control" value="@Model.Age"  placeholder="Enter your age">
        <span class="text-danger" asp-validation-for="Age"> </span>

</div>
<div class="mb-3">
    <label class="form-label">Score</label>
        <input type="number" name="Score" class="form-control" value="@Model.Score" placeholder="Enter your score">
        <span class="text-danger" asp-validation-for="Score"> </span>

</div>
    <button type="submit" class="btn btn-outline-primary">Add</button>

</form>
